# Runtime database connection. Use the pooled Neon URL in production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Direct database connection for Prisma CLI and migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Optional client override for Better Auth when the browser must talk to a different origin.
NEXT_PUBLIC_BETTER_AUTH_URL=""

# Credential encryption. If omitted, the app falls back to BETTER_AUTH_SECRET.
CREDENTIAL_ENCRYPTION_KEY=""

# Inngest Cloud. Not required for local dev with `inngest-cli dev`.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
INNGEST_SIGNING_KEY_FALLBACK=""

# Optional. Set this if Inngest should sync against your production custom domain.
INNGEST_SERVE_HOST=""

# Optional AI providers
GOOGLE_GENERATIVE_AI_API_KEY=""
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
MINIMAX_BASE_URL="https://api.minimaxi.com/anthropic/v1"

# Optional AI proxy flags
GOOGLE_USE_PROXY="false"
GOOGLE_PROXY_URL=""
OPENAI_USE_PROXY="false"
ANTHROPIC_USE_PROXY="false"
MINIMAX_USE_PROXY="false"

# Optional Paddle billing
NEXT_PUBLIC_PADDLE_ENV="sandbox"
PADDLE_API_KEY=""
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
PADDLE_PRO_PRICE_ID=""
PADDLE_WEBHOOK_SECRET=""
PADDLE_WEBHOOK_TOLERANCE_SECONDS="30"

# Optional Sentry build integration
SENTRY_AUTH_TOKEN=""

# Optional MCP server scaffold. JSON array of server configs.
# Example:
# MCP_SERVERS_JSON='[{"id":"filesystem","displayName":"Filesystem MCP","description":"Local file tools","transport":"STDIO","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","E:/OneDrive/code/nodebase"]}]'
MCP_SERVERS_JSON=""
